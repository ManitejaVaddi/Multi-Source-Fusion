###############################################
# SERVER CONFIGURATION
###############################################
FUSION_HOST=127.0.0.1
FUSION_PORT=8000
DEBUG=false

###############################################
# MONGODB CONFIGURATION (Live Mode)
###############################################
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=intelligence
MONGO_COLLECTION=osint_records

###############################################
# AWS S3 CONFIGURATION (Live Mode)
###############################################
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=your-osint-bucket
AWS_S3_PREFIX=osint/
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

###############################################
# AUTHENTICATION (JWT)
###############################################
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

###############################################
# IMAGE UPLOAD SETTINGS
###############################################
IMAGE_UPLOAD_BACKEND=local
# Options: 'local' (file system) or 's3' (AWS S3)
# Set to 's3' for production
MAX_IMAGE_SIZE_MB=50

###############################################
# DATA STORAGE SETTINGS
###############################################
MANUAL_REPORTS_BACKEND=json
# Options: 'json' (file-based) or 'mongodb' (database)
# Set to 'mongodb' for production
